# ==================== CORE SETTINGS (REQUIRED) ====================
# [REQUIRED] Get your bot token from @BotFather on Telegram. This connects the engine to your Telegram bot.
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
chat_id =
# [REQUIRED] Get your API key from https://aistudio.google.com/app/apikey. This gives the engine its "brain" for writing captions and finding watermarks.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ==================== DOWNLOADER & SOCIAL LOGINS ====================
# [Optional] If you download heavily from Instagram, provide a cookies file and username/password to prevent getting blocked.
COOKIES_FILE=cookies.txt
IG_USERNAME=
IG_PASSWORD=

# ==================== PC PERFORMANCE ====================
# How should the engine use your computer? 'on' forces it, 'off' disables it, 'auto' lets it decide.
CPU_MODE=auto
GPU_MODE=auto

# How hard should it compress the video? (preset: fast/slow. crf: lower number = larger file size/better quality. 18-25 is good).
REENCODE_PRESET=fast
REENCODE_CRF=18

# Should the program prioritize 'quality' (crystal clear, slow upload) or 'speed' (faster, smaller file)?
RENDER_TARGET=quality

# ==================== VISUAL ENHANCEMENTS & CROPPING ====================
# How much should the video be enhanced? (low, medium, high)
ENHANCEMENT_LEVEL=medium
# Tries to keep skin tones natural when enhancing. (yes/no)
PRO_SKIN_STABILITY=yes
# The final video size. 1080:1920 is standard for TikTok/Reels/Shorts.
TARGET_RESOLUTION=1080:1920

# Should the engine auto-crop the video to focus on the subject? (yes/no)
ENABLE_SMART_CROP=no
# If 'yes', it completely stops cropping from happening safely. (yes/no)
FORCE_NO_CROP=yes
# Flips the video horizontally to bypass copyright filters. (yes/no)
MIRROR_VIDEO=no

# ==================== TRANSFORMATIVE FILTERS ====================
# Should it add cinematic colors to make it look premium? (yes/no)
ADD_COLOR_GRADING=yes
COLOR_FILTER=cinematic
# How strong should the color grading be? (0.1 to 1.0)
COLOR_INTENSITY=0.5

# Should it slightly fast-forward and slow down the video randomly to bypass copyright? (yes/no)
ADD_SPEED_RAMPING=yes
SPEED_VARIATION=0.15

# ==================== WATERMARK REMOVAL ====================
# Should it remove old watermarks? (yes/no)
ENABLE_WATERMARK_REMOVAL=yes
# Should Gemini AI help look for watermarks? (yes/no)
ENABLE_GEMINI_WATERMARK_DETECT=yes
# Maximum screen percentage a watermark can cover before it gives up (1-100)
WATERMARK_MAX_AREA_PERCENT=15

# [Advanced] Words for the AI to look for and erase as watermarks (Comma separated).
WATERMARK_DETECT_TEXT=watermark,logo,text overlay
WATERMARK_DETECT_LIST=

# [Advanced Quality] Quality preset: turbo (fastest), balanced (default), precise (best quality).
WATERMARK_ENGINE_PRESET=balanced
# [Autopilot] Let the AI choose the best removal methods. Keep at 'auto' for best results.
WATERMARK_INPAINT_STRATEGY=auto
WATERMARK_ADAPTIVE_STRATEGY=auto
WATERMARK_MODE_OVERRIDE=auto
WATERMARK_INPAINT_QUALITY=auto
WATERMARK_SMART_TRACKING=stable

# ==================== YOUR BRAND WATERMARK ====================
# Should the engine add YOUR image watermark over the video? (yes/no)
ENABLE_WATERMARK_REPLACEMENT=yes
WATERMARK_REPLACE_PATH=assets/watermark.png
# How visible should your watermark be? (0.1 to 1.0)
MY_WATERMARK_OPACITY=0.80

# Should it write text on the video (like your channel name)? (yes/no)
ADD_TEXT_OVERLAY=yes
TEXT_OVERLAY_CONTENT="swargawasal"
MY_WATERMARK_TEXT="swargawasal"
TEXT_OVERLAY_POSITION=bottom
TEXT_OVERLAY_SIZE=60
TEXT_OVERLAY_BOX=no

# ==================== AUDIO REMIXING ====================
# Should it completely remix the audio to bypass copyright? (yes/no)
FORCE_AUDIO_REMIX=yes
# Enable heavy audio bass/reverb remixing for shorts? (yes/no)
ENABLE_HEAVY_REMIX_SHORTS=yes
# Enable heavy audio remixing for long compilations? (yes/no)
ENABLE_HEAVY_REMIX_COMPILATION=yes

# Should it automatically add background music? (yes/no)
AUTO_MUSIC=no
# Background music volume (0.1 to 1.0)
MUSIC_VOLUME=0.4
# How loud should the original video sound be? (1.0 is normal loudness, 0.5 is half)
ORIGINAL_AUDIO_VOLUME=1.0

# Keep the original audio logic fallbacks if remixing fails
KEEP_ORIGINAL_AUDIO=yes
FALLBACK_AUDIO=yes

# ==================== AI CAPTIONS & INTELLIGENCE ====================
# Should the AI generate viral captions for your posts? (yes/no)
AI_CAPTIONS=yes
# Suggest hashtags automatically? (yes/no)
HASHTAG_GEN=no
# What kind of captions should it write? (Leave blank for auto, or put "Funny", "Professional")
AI_CAPTION_STYLE=
AI_CAPTION_TOPIC=

# ==================== AZURE VOICEOVER ====================
# If you want AI voiceovers, get keys from Microsoft Azure Cognitive Services
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# Should the bot add micro-narrations over the video? (yes/no)
ENABLE_MICRO_VOICEOVER=yes

# ==================== NEW: SMART PRICE TAG ====================
# Analyzes fashion and slaps a smart price tag overlay on the video (yes/no)
ENABLE_PRICE_TAG=yes
# Your Brand Handle/Name
BRAND_NAME="@imidhunkrishna"

# ==================== COMPILATION (STITCHING VIDEOS) ====================
# How many short videos to stitch together into one long video?
COMPILATION_BATCH_SIZE=20
# Should long videos get an intro clip? (yes/no)
ENABLE_COMPILATION_INTRO=yes
# Transition length between clips in seconds
TRANSITION_DURATION=0.5
TRANSITION_INTERVAL=5

# ==================== YOUTUBE AUTO-UPLOAD ====================
# Should it upload to YouTube automatically? (on/off)
SEND_TO_YOUTUBE=off
# Paths to your YouTube API credentials (required if uploading)
CLIENT_SECRET_FILE=Credentials/client_secret.json
YOUTUBE_TOKEN_FILE=Credentials/token.json
# Auto-hashtags for YouTube
DEFAULT_HASHTAGS_SHORTS=#shorts #viral #trending
DEFAULT_HASHTAGS_COMPILATION=#compilation #funny #viral
# Post to the YouTube Community Tab? (yes/no)
ENABLE_COMMUNITY_POST_COMPILATION=yes
ENABLE_COMMUNITY_POST_SHORTS=yes

# ==================== INSTAGRAM & FACEBOOK AUTO-UPLOAD ====================
# Master switch to allow Meta platforms uploads (yes/no)
ENABLE_META_UPLOAD=yes
# Should it upload long compilations to Meta? (yes/no)
META_COMPILE_UPLOAD=no
# Should it post as a Reel or a Post?
META_UPLOAD_TYPE=Reels
META_UPLOAD_TYPE_FB=Post
# Auto upload destination toggles (on/off)
SEND_TO_INSTAGRAM=off
SEND_TO_FACEBOOK=off

# Connect to Facebook/Instagram (Need Meta Developer API access)
META_PAGE_ID=
META_PAGE_TOKEN=
IG_BUSINESS_ID=
IG_BUSINESS_TOKEN=

# ==================== AFFILIATE / MONETIZATION ====================
# Auto-generate affiliate/store links? (yes/no)
ENABLE_FASHION_SCOUT=yes
# Link rules format overrides
LOS_POLLOS_YOUTUBE=no
LOS_POLLOS_TELEGRAM=yes

# ==================== SYSTEM & NETWORK SETTINGS ====================
# Network retry logic. If the internet fails, try this many times.
NET_RETRY_COUNT=3
NET_BACKOFF_BASE=2.0
# Telegram file limit size (in MB, max 50 for free bot)
TELEGRAM_MAX_UPLOAD_MB=50

# ==================== ADVANCED / DEVELOPER SETTINGS ====================
# Usually don't need to change these
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT=30
GEMINI_MAX_RETRIES=2
GEMINI_FAILOVER=yes
CAPTION_PROMPT_FILE=The_json/caption_prompt.json
SESSION_TTL_SECS=86400
LOCK_WAIT_SECS=5
WATERMARK_2STEP_VERIFICATION=off
ENABLE_GEMINI_ENHANCE=no
GEMINI_TITLE_COMPLICATION=on
ENABLE_TREMOLO=no
COMPILATION_MASTER_MODE=heavy


# Optional: Local Telegram Bot API Server URL for 0-second uploads (e.g., http://localhost:8081/bot)
# LOCAL_BOT_API_URL=

# FFmpeg Output Optimization. Options: 'quality' (CRF 20, 46MB, slow upload), 'speed' (CRF 26, 15MB, fast upload)
RENDER_TARGET=quality

# Enables or Disables the Smart Price Tag Overlay (yes/no)
ENABLE_PRICE_TAG=yes
FACE_ENHANCEMENT=yes
USE_ADVANCED_ENGINE=on


# Optional: Local Telegram Bot API Server URL for 0-second uploads (e.g., http://localhost:8081/bot)
# LOCAL_BOT_API_URL=

# FFmpeg Output Optimization. Options: 'quality' (CRF 20, 46MB, slow upload), 'speed' (CRF 26, 15MB, fast upload)
RENDER_TARGET=quality

# Enables or Disables the Smart Price Tag Overlay (yes/no)
ENABLE_PRICE_TAG=yes
